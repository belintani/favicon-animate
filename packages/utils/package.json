{
  "name": "favicon-animate-utils",
  "version": "0.3.1",
  "description": "Advanced utilities for favicon-animate: GIF/WebP parsing, canvas animations, events, themes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "favicon",
    "animate",
    "gif",
    "webp",
    "canvas",
    "events",
    "theme"
  ],
  "author": "Daniel Belintani <daniel.belintani@hotmail.com>",
  "license": "MIT",
  "dependencies": {
    "favicon-animate": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/node": "^20.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
