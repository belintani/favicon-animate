{
  "name": "favicon-animate-monorepo",
  "version": "0.1.0",
  "description": "Complete favicon management library with dynamic animations, badges, and multi-format support",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/utils",
    "website"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "docs": "cd website && pnpm run dev",
    "clean": "pnpm -r run clean && rm -rf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/ui": "^0.34.0",
    "@vitest/coverage-v8": "^0.34.0",
    "eslint": "^8.0.0",
    "jsdom": "^22.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "author": "Daniel Belintani <daniel.belintani@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/belintani/favicon-animate"
  },
  "keywords": [
    "favicon",
    "animate",
    "dynamic",
    "gif",
    "webp",
    "badge",
    "notification",
    "icon"
  ]
}
